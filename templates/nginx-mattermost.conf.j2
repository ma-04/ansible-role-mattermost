{{ ansible_managed | comment }}
{% set stage = mattermost_nginx_stage | default('final') %}
{% set tls = mattermost_tls_mode %}
{% set upstream = mattermost_bind_address + ':' + (mattermost_listen_port | string) %}

map $http_upgrade $mattermost_connection_upgrade {
    default upgrade;
    ''      close;
}

{% macro proxy_app() %}
        client_max_body_size {{ mattermost_max_file_size }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $mattermost_connection_upgrade;
        proxy_http_version 1.1;
        proxy_read_timeout 600s;
        proxy_pass http://{{ upstream }};
{% endmacro %}

server {
    listen 80;
    listen [::]:80;
    server_name {{ mattermost_domain }};

{% if tls == 'letsencrypt' %}
    location /.well-known/acme-challenge/ {
        root {{ mattermost_letsencrypt_webroot }};
    }
{% endif %}

{% if stage == 'bootstrap' or tls == 'none' %}
    location ~ /api/v[0-9]+/(users/)?websocket$ {
{{ proxy_app() }}
    }

    location / {
{{ proxy_app() }}
    }
{% else %}
    location / {
        return 301 https://$host$request_uri;
    }
{% endif %}
}

{% if stage == 'final' and tls != 'none' %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ mattermost_domain }};

    ssl_certificate {{ mattermost_tls_cert_path }};
    ssl_certificate_key {{ mattermost_tls_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:MATTERMOST:10m;
    ssl_session_timeout 1d;

    location ~ /api/v[0-9]+/(users/)?websocket$ {
{{ proxy_app() }}
    }

    location / {
{{ proxy_app() }}
    }
}
{% endif %}
