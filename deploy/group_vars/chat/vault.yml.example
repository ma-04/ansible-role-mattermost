---
# Secrets. Copy to vault.yml, fill in, then encrypt:
#   cp vault.yml.example vault.yml && ansible-vault encrypt vault.yml
# vault.yml is git-ignored. Full docs: ../../../README.md

vault_mm_db_password: "CHANGE_ME_DB_PASSWORD"

# Only for mattermost_tls_mode: cloudflare_origin
vault_mm_origin_cert: |
  -----BEGIN CERTIFICATE-----
  PASTE_CLOUDFLARE_ORIGIN_CERT_HERE
  -----END CERTIFICATE-----
vault_mm_origin_key: |
  -----BEGIN PRIVATE KEY-----
  PASTE_CLOUDFLARE_ORIGIN_PRIVATE_KEY_HERE
  -----END PRIVATE KEY-----

# vault_cf_api_token: "..."             # for mattermost_cloudflare_enabled
# vault_mm_gitlab_client_secret: "..."  # for mattermost_gitlab_auth_enabled
