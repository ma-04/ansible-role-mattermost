---
# Non-secret role config. Copy to vars.yml and edit. Full docs: ../../../README.md
# Secrets go in vault.yml (see vault.yml.example).

mattermost_install_method: "apt"       # apt | tarball
mattermost_edition: "community"        # apt: community; tarball: team | enterprise
mattermost_version: ""                 # apt: pin or latest; tarball: exact release (required)

mattermost_site_url: "https://chat.example.com"

mattermost_db_type: "external"         # local | external
mattermost_db_name: "mattermost"
mattermost_db_user: "mmadmin"
mattermost_db_password: "{{ vault_mm_db_password }}"
mattermost_db_host: "db.example.com"   # external only
mattermost_db_port: 5432
mattermost_db_sslmode: "require"

mattermost_nginx_enabled: true
mattermost_tls_mode: "cloudflare_origin"   # letsencrypt | cloudflare_origin | none
mattermost_cloudflare_origin_cert: "{{ vault_mm_origin_cert }}"
mattermost_cloudflare_origin_key: "{{ vault_mm_origin_key }}"

mattermost_configure_firewall: false   # true if no cloud firewall/NSG handles 80/443
mattermost_cloudflare_enabled: false   # true to manage DNS + zone SSL via the CF API
mattermost_gitlab_auth_enabled: false  # true for GitLab OAuth / OIDC SSO
