# Copy to inventory.ini and fill in your host details.
#   cp inventory.ini.example inventory.ini
# inventory.ini is git-ignored (it holds environment-specific values).

[chat]
mattermost ansible_host=203.0.113.10

[chat:vars]
ansible_user=azureuser
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3
